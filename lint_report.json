nta el porqu├® de cada n├║mero m├ígico.\n */\n\n/**\n * Factores de ajuste para proyecciones de ventas\n * Basado en an├ílisis hist├│ricos de patrones de consumo\n */\nexport const PROJECTION_FACTORS = {\n    /**\n     * Multiplicador para fines de semana (viernes/s├íbado)\n     * Hist├│ricamente las ventas aumentan ~20% estos d├¡as\n     */\n    WEEKEND_MULTIPLIER: 1.2,\n    \n    /**\n     * Multiplicador para d├¡as laborables\n     * Sin ajuste significativo\n     */\n    WEEKDAY_MULTIPLIER: 1.0,\n} as const\n\n/**\n * Estimaciones de impacto financiero\n * Valores conservadores para c├ílculos de alertas\n */\nexport const INFLATION_ESTIMATES = {\n    /**\n     * Impacto estimado en euros por cada alerta de spike de precio\n     * Basado en: volumen promedio afectado ├ù incremento de precio\n     */\n    PER_ALERT_IMPACT_EUR: 50,\n} as const\n\n/**\n * Ratios de gastos por defecto para estimaciones\n * Utilizados cuando no hay datos hist├│ricos detallados\n */\nexport const EXPENSE_RATIOS = {\n    /**\n     * Porcentaje de ventas destinado a Coste de Bienes (COGS)\n     * Est├índar industria: 25-35%\n     */\n    DEFAULT_COGS_PCT: 0.30,     // 30%\n    \n    /**\n     * Porcentaje de ventas destinado a Personal\n     * Est├índar industria: 30-35%\n     */\n    DEFAULT_LABOR_PCT: 0.35,   // 35%\n    \n    /**\n     * Porcentaje de ventas destinado a Gastos Fijos\n     * Incluye: alquiler, suministros, seguros, mantenimiento\n     */\n    DEFAULT_FIXED_PCT: 0.35,     // 35%\n} as const\n\n/**\n * Objetivos de ratios financieros (KPIs)\n * Metas a alcanzar para restaurante saludable\n */\nexport const TARGET_RATIOS = {\n    /**\n     * Coste Personal objetivo como % de ventas\n     * Ideal: 28-33%\n     */\n    PERSONAL_TARGET_PCT: 33,\n    \n    /**\n     * Coste Materia Prima objetivo como % de ventas\n     * Ideal: 28-32%\n     */\n    COGS_TARGET_PCT: 33,\n    \n    /**\n     * Prime Cost objetivo (Personal + COGS)\n     * Ideal: Ôëñ 60% de ventas\n     */\n    PRIME_COST_MAX_PCT: 60,\n} as const\n\n/**\n * Categor├¡as de gastos para agrupaci├│n\n */\nexport const EXPENSE_CATEGORIES = {\n    PERSONAL: [\n        'NOMINAS_LIQUIDAS',\n        'SEGURIDAD_SOCIAL',\n        'EN_MANO_PERSONAL'\n    ] as const,\n    \n    COGS: [\n        'PROVEEDORES_COMIDA',\n        'PROVEEDORES_BEBIDA',\n        'VARIACION_EXISTENCIAS'\n    ] as const,\n    \n    INVESTMENTS: [\n        'INVERSIONES'\n    ] as const,\n} as const\n\n/**\n * Utilidades de validaci├│n\n */\nexport const isPersonalCategory = (category: string): boolean => \n    EXPENSE_CATEGORIES.PERSONAL.includes(category as any)\n\nexport const isCOGSCategory = (category: string): boolean =>\n    EXPENSE_CATEGORIES.COGS.includes(category as any)\n\nexport const isInvestmentCategory = (category: string): boolean =>\n    EXPENSE_CATEGORIES.INVESTMENTS.includes(category as any)\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Usuario\\.gemini\\antigravity\\playground\\app finanzas restaurante\\src\\lib\\financial-math.test.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Usuario\\.gemini\\antigravity\\playground\\app finanzas restaurante\\src\\lib\\financial-math.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Usuario\\.gemini\\antigravity\\playground\\app finanzas restaurante\\src\\lib\\financial-theme.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Usuario\\.gemini\\antigravity\\playground\\app finanzas restaurante\\src\\lib\\financial-utils.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"f