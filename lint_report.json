n\r\n    // Avg Yield\r\n    const avgWaste = ingredients.reduce((acc, curr) => acc + (curr.standard_waste_pct || 0), 0) / (totalIngredients || 1)\r\n    const avgYield = ((1 - avgWaste) * 100).toFixed(1)\r\n\r\n    // Most Expensive\r\n    const mostExpensive = ingredients.reduce((prev, current) => {\r\n        return (prev.current_avg_price || 0) > (current.current_avg_price || 0) ? prev : current\r\n    }, {} as MasterIngredient)\r\n\r\n    return (\r\n        <div className=\"grid gap-4 md:grid-cols-2 lg:grid-cols-4\">\r\n            <Card>\r\n                <CardHeader className=\"flex flex-row items-center justify-between space-y-0 pb-2\">\r\n                    <CardTitle className=\"text-sm font-medium\">\r\n                        Total Ingredientes\r\n                    </CardTitle>\r\n                    <Package className=\"h-4 w-4 text-muted-foreground\" />\r\n                </CardHeader>\r\n                <CardContent>\r\n                    <div className=\"text-2xl font-bold\">{totalIngredients}</div>\r\n                    <p className=\"text-xs text-muted-foreground\">\r\n                        Productos registrados\r\n                    </p>\r\n                </CardContent>\r\n            </Card>\r\n\r\n            <Card>\r\n                <CardHeader className=\"flex flex-row items-center justify-between space-y-0 pb-2\">\r\n                    <CardTitle className=\"text-sm font-medium\">\r\n                        Rendimiento Promedio\r\n                    </CardTitle>\r\n                    <TrendingUp className=\"h-4 w-4 text-muted-foreground\" />\r\n                </CardHeader>\r\n                <CardContent>\r\n                    <div className=\"text-2xl font-bold\">{avgYield}%</div>\r\n                    <p className=\"text-xs text-muted-foreground\">\r\n                        Eficiencia global\r\n                    </p>\r\n                </CardContent>\r\n            </Card>\r\n\r\n            <Card>\r\n                <CardHeader className=\"flex flex-row items-center justify-between space-y-0 pb-2\">\r\n                    <CardTitle className=\"text-sm font-medium\">\r\n                        Mayor Coste Base\r\n                    </CardTitle>\r\n                    <DollarSign className=\"h-4 w-4 text-muted-foreground\" />\r\n                </CardHeader>\r\n                <CardContent>\r\n                    <div className=\"text-2xl font-bold\">\r\n                        {mostExpensive.current_avg_price?.toFixed(2) || \"0.00\"} Ôé¼\r\n                    </div>\r\n                    <p className=\"text-xs text-muted-foreground truncate\">\r\n                        {mostExpensive.name || \"-\"}\r\n                    </p>\r\n                </CardContent>\r\n            </Card>\r\n        </div>\r\n    )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Usuario\\.gemini\\antigravity\\playground\\app finanzas restaurante\\src\\components\\ingredients\\IngredientsClientPage.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Usuario\\.gemini\\antigravity\\playground\\app finanzas restaurante\\src\\components\\ingredients\\IngredientsTable.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'AllergenBadges' is defined but never used. Allowed unused vars must match /^_/u.","line":17,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":17,"endColumn":24,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"AllergenBadges"},"fix":{"range":[534,585],"text":""},"desc":"Remove unused import declaration."}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState } from \"react\"\nimport { MasterIngredient } from \"@/types/schema\"\nimport {\n    Table,\n    TableBody,\n    TableCell,\n    TableHead,\n    TableHeader,\n    TableRow,\n} from \"@/components/ui/table\"\nimport { Button } from \"@/components/ui/button\"\nimport { Input } from \"@/components/ui/input\"\nimport { Badge } from \"@/components/ui/badge\"\nimport { updateIngredientPrice, updateIngredientWaste } from \"@/app/actions/ingredients\"\nimport { toast } from \"sonner\"\nimport { DeleteIngredientAlert } from \"./DeleteIngredientAlert\"\nimport { AllergenBadges } from \"./AllergenSelector\"\nimport { Check, X } from \"lucide-react\"\n\ninterface Props {\n    ingredients: MasterIngredient[]\n    onDelete?: (id: string) => void\n}\n\nexport function IngredientsTable({ ingredients, onDelete }: Props) {\n    const [editingId, setEditingId] = useState<string | null>(null)\n    const [tempWaste, setTempWaste] = useState<string>(\"\")\n    const [tempPrice, setTempPrice] = useState<string>(\"\")\n\n    const startEditing = (ing: MasterIngredient) => {\n        setEditingId(ing.id!)\n        setTempWaste((ing.standard_waste_pct * 100).toString())\n        setTempPrice(ing.current_avg_price.toString())\n    }\n\n    const cancelEditing = () => {\n        setEditingId(null)\n    }\n\n    const saveChanges = async (id: string) => {\n        try {\n            const waste = parseFloat(tempWaste) / 100\n            const price = parseFloat(tempPrice)\n\n            if (isNaN(waste) || isNaN(price)) {\n                toast.error(\"N├║meros inv├ílidos\")\n                return\n            }\n\n            // Optimistic update essentially happens via revalidatePath, \n            // but we close edit mode immediately to feel responsive\n            setEditingId(null)\n\n            await Promise.all([\n                updateIngredientWaste(id, waste),\n                updateIngredientPrice(id, price)\n            ])\n\n            toast.success(\"Ingrediente actualizado\")\n        } catch {\n            toast.error(\"Error al actualizar\")\n            // Re-open edit mode if failed? Ideally yes, but let's keep it simple for now\n        }\n    }\n\n    const getYieldBadgeVariant = (wastePct: number) => {\n        const yieldPct = (1 - wastePct) * 100\n        if (yieldPct >= 95) return \"default\" // Greenish in strict themes, or customize\n        if (yieldPct >= 80) return \"secondary\" // Yellow/Orange\n        return \"destructive\" // Red\n    }\n\n    const getYieldLabel = (wastePct: number) => {\n        const yieldPct = (1 - wastePct) * 100\n        return `${yieldPct.toFixed(1)}%`\n    }\n\n    if (ingredients.length === 0) {\n        return (\n            <div className=\"flex flex-col items-center justify-center p-12 border rounded-lg bg-muted/10 border-dashed\">\n                <p className=\"text-muted-foreground text-center\">\n                    No hay ingredientes todav├¡a.\n                    <br />\n                    ┬íCrea el primero arriba!\n                </p>\n            </div>\n        )\n    }\n\n    return (\n        <div className=\"rounded-lg border border-border overflow-hidden shadow-sm animate-fade-in-up bg-white\">\n            <Table>\n                <TableHeader>\n                    <TableRow className=\"bg-muted/30 hover:bg-muted/30\">\n                        <TableHead className=\"font-semibold w-[25%]\">Ingrediente</TableHead>\n                        <TableHead className=\"font-semibold w-[10%]\">Unidad</TableHead>\n                        <TableHead className=\"font-semibold w-[15%]\">Rendimiento</TableHead>\n                        <TableHead className=\"font-semibold w-[20%]\">Al├®rgenos</TableHead>\n                        <TableHead className=\"w-[100px]\">Merma</TableHead>\n                        <TableHead className=\"w-[100px]\">Precio (Ôé¼)</TableHead>\n                        <TableHead className=\"text-right w-[100px]\">Acciones</TableHead>\n                    </TableRow>\n                </TableHeader>\n                <TableBody>\n                    {ingredients.map((ing, index) => {\n                        const isEditing = editingId === ing.id\n                        const delay = (index % 10) * 50 // Staggered animation\n\n                        return (\n                            <TableRow\n                                key={ing.id}\n                                className=\"group hover:bg-muted/50 transition-colors\"\n                                style={{ animationDelay: `${delay}ms` }}\n                            >\n                                <TableCell className=\"font-medium text-foreground\">\n                                    <div className=\"flex flex-col\">\n                                        <span>{ing.name}</span>\n                                        {ing.category && (\n                                            <span className=\"text-xs text-muted-foreground font-normal\">{ing.category}</span>\n                                        )}\n                                    </div>\n                                </TableCell>\n                                <TableCell>\n                                    <Badge variant=\"outline\" className=\"font-mono text-xs uppercase\">\n                                        {ing.base_unit}\n                                    </Badge>\n                                </TableCell>\n                                <TableCell>\n                                    {isEditing ? (\n                                        <div className=\"flex items-center gap-2\">\n                                            <Input\n                                                type=\"number\"\n                                                step=\"0.1\"\n                                                min=\"0\"\n                                                max=\"100\"\n                                                className=\"w-16 h-8 text-right\"\n                                                value={tempWaste}\n                                                onChange={(e) => setTempWaste(e.target.value)}\n                                            />\n                                            <span className=\"text-xs text-muted-foreground flex flex-col\">\n                                                <span>% merma</span>\n                                            </span>\n                                        </div>\n                                    ) : (\n                                        <Badge variant={getYieldBadgeVariant(ing.standard_waste_pct)}>\n                                            {getYieldLabel(ing.standard_waste_pct)}\n                                        </Badge>\n                                    )}\n                                </TableCell>\n                                <TableCell>\n                                    {/* TODO: Add allergens support - requires DB migration */}\n                                    <span className=\"text-xs text-muted-foreground\">-</span>\n                                </TableCell>\n                                <TableCell>\n                                    <div className=\"flex items-center gap-2\">\n                                        <div className=\"h-2 w-16 rounded-full bg-secondary overflow-hidden\">\n                                            <div\n                                                className={`h-full ${(ing.standard_waste_pct || 0) > 0.15 ? 'bg-destructive' : 'bg-green-500'\n                                                    }`}\n                                                style={{ width: `${(ing.standard_waste_pct || 0) * 100}%` }}\n                                            />\n                                        </div>\n                                        <span className=\"text-xs text-muted-foreground w-8 text-right\">\n                                            {((ing.standard_waste_pct || 0) * 100).toFixed(0)}%\n                                        </span>\n                          