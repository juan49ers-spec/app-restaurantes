ack to decimals for storage\r\n                cogs_target_pct: (values.cogs_target_pct || 0) / 100,\r\n                labor_target_pct: (values.labor_target_pct || 0) / 100\r\n            }\r\n            const result = await upsertMonthlyTarget(submitData as MonthlyTarget)\r\n            if (!result.success) throw new Error(result.error)\r\n            toast.success(\"Objetivos actualizados correctamente\")\r\n            onSuccess?.()\r\n        } catch (error) {\r\n            toast.error(\"Error al guardar objetivos\")\r\n            console.error(error)\r\n        } finally {\r\n            setIsSubmitting(false)\r\n        }\r\n    }\r\n\r\n    const FormContent = (\r\n        <form onSubmit={form.handleSubmit(onSubmit)} className=\"space-y-6\">\r\n            <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\r\n                <div className=\"space-y-2\">\r\n                    <Label className=\"flex items-center gap-2 text-slate-700\">\r\n                        <Euro className=\"w-3.5 h-3.5 text-slate-400\" /> Presupuesto de Ventas (Ôé¼)\r\n                    </Label>\r\n                    <Input\r\n                        type=\"number\"\r\n                        placeholder=\"45000\"\r\n                        {...form.register('revenue_target', { valueAsNumber: true })}\r\n                        className=\"font-mono\"\r\n                    />\r\n                </div>\r\n                <div className=\"space-y-2\">\r\n                    <Label className=\"flex items-center gap-2 text-slate-700\">\r\n                        <Percent className=\"w-3.5 h-3.5 text-slate-400\" /> Objetivo Materia Prima (%)\r\n                    </Label>\r\n                    <Input\r\n                        type=\"number\"\r\n                        step=\"0.1\"\r\n                        placeholder=\"28\"\r\n                        {...form.register('cogs_target_pct', { valueAsNumber: true })}\r\n                        className=\"font-mono\"\r\n                    />\r\n                </div>\r\n                <div className=\"space-y-2\">\r\n                    <Label className=\"flex items-center gap-2 text-slate-700\">\r\n                        <Percent className=\"w-3.5 h-3.5 text-slate-400\" /> Objetivo Personal (%)\r\n                    </Label>\r\n                    <Input\r\n                        type=\"number\"\r\n                        step=\"0.1\"\r\n                        placeholder=\"25\"\r\n                        {...form.register('labor_target_pct', { valueAsNumber: true })}\r\n                        className=\"font-mono\"\r\n                    />\r\n                </div>\r\n            </div>\r\n\r\n            <div className=\"flex justify-end pt-2\">\r\n                <Button type=\"submit\" disabled={isSubmitting} className=\"bg-blue-600 hover:bg-blue-700\">\r\n                    {isSubmitting ? (\r\n                        <>\r\n                            <Loader2 className=\"mr-2 h-4 w-4 animate-spin\" /> Guardando...\r\n                        </>\r\n                    ) : (\r\n                        <>\r\n                            <Save className=\"mr-2 h-4 w-4\" /> Guardar Objetivos\r\n                        </>\r\n                    )}\r\n                </Button>\r\n            </div>\r\n        </form>\r\n    )\r\n\r\n    if (!showCard) return FormContent\r\n\r\n    return (\r\n        <Card className=\"border-slate-200 shadow-sm overflow-hidden bg-white\">\r\n            <div className=\"absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-blue-600 to-indigo-600\" />\r\n            <CardHeader>\r\n                <div className=\"flex items-center gap-2 mb-1\">\r\n                    <Target className=\"w-5 h-5 text-blue-600\" />\r\n                    <CardTitle>Presupuesto Mensual ÔÇö {currentMonth}</CardTitle>\r\n                </div>\r\n                <CardDescription>\r\n                    Define tus metas para calcular desviaciones y rendimiento real.\r\n                </CardDescription>\r\n            </CardHeader>\r\n            <CardContent>\r\n                {FormContent}\r\n            </CardContent>\r\n        </Card>\r\n    )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Usuario\\.gemini\\antigravity\\playground\\app finanzas restaurante\\src\\components\\financial-control\\OperationalStats.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Usuario\\.gemini\\antigravity\\playground\\app finanzas restaurante\\src\\components\\financial-control\\PnLReport.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Usuario\\.gemini\\antigravity\\playground\\app finanzas restaurante\\src\\components\\financial-control\\ProfitBridge.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Usuario\\.gemini\\antigravity\\playground\\app finanzas restaurante\\src\\components\\financial-control\\ResultadoNetoCard.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Usuario\\.gemini\\antigravity\\playground\\app finanzas restaurante\\src\\components\\financial-control\\ResultadosDashboard.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Usuario\\.gemini\\antigravity\\playground\\app finanzas restaurante\\src\\components\\financial-control\\ResultadosSkeleton.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErro