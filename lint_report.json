ense(expense)\n        setIsFormOpen(true)\n    }\n\n    const handleDeleteExpense = async (id: string) => {\n        if (!confirm(\"┬┐Est├ís seguro de eliminar este gasto?\")) return\n        try {\n            const { deleteOperatingExpense } = await import(\"@/app/actions/financial-control\")\n            await deleteOperatingExpense(id)\n            toast.success(\"Gasto eliminado\")\n            // Force refresh\n            window.location.reload()\n        } catch {\n            toast.error(\"Error al eliminar\")\n        }\n    }\n\n    const handleExport = () => {\n        // Flatten all expenses from all categories\n        const allExpenses = data.categories.flatMap(cat =>\n            cat.expenses.map((exp: any) => ({\n                date: exp.date,\n                category: cat.category,\n                description: exp.description || '',\n                provider_detail: exp.provider_detail || '',\n                tag: exp.tag || '',\n                amount: exp.amount,\n                payment_method: exp.payment_method,\n                is_paid: exp.is_paid,\n                taxable_amount: exp.taxable_amount,\n                tax_rate: exp.tax_rate,\n                tax_amount: exp.tax_amount,\n                withholding_rate: exp.withholding_rate,\n                withholding_amount: exp.withholding_amount\n            }))\n        )\n\n        const monthYear = data.history.length > 0 ? data.history[data.history.length - 1].month : 'current'\n        exportExpensesToCSV(allExpenses, `gastos_${monthYear}.csv`)\n        toast.success(\"Gastos exportados correctamente\")\n    }\n\n    const handleInsightEdit = (summary: string) => {\n        if (onInsightEdit) {\n            onInsightEdit(summary)\n        }\n    }\n\n    return (\n        <motion.div\n            className=\"space-y-6\"\n            variants={container}\n            initial=\"hidden\"\n            animate=\"show\"\n        >\n            {/* Header with Title and Add Button */}\n            <motion.div variants={item} className=\"flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 border-b border-neutral-200 pb-6\">\n                <div>\n                    <h2 className=\"text-2xl font-bold text-neutral-900 tracking-tight\">Control de Gastos</h2>\n                    <p className=\"text-sm text-neutral-500 mt-1\">Gestiona y analiza todos los gastos operativos del mes</p>\n                </div>\n                <Button\n                    onClick={() => {\n                        setEditingExpense(null)\n                        setIsFormOpen(true)\n                    }}\n                    className=\"bg-neutral-900 hover:bg-neutral-800 text-white gap-2 rounded-xl px-6 py-2.5 font-bold text-sm transition-all shadow-sm hover:shadow-md active:scale-95\"\n                >\n                    <Plus className=\"w-4 h-4\" />\n                    <span>A├▒adir Gasto</span>\n                </Button>\n            </motion.div>\n\n            {/* Top Row: KPIs (66%) + Chart (33%) */}\n            <motion.div variants={item} className=\"grid grid-cols-1 xl:grid-cols-3 gap-6\">\n                <div className=\"xl:col-span-2\">\n                    <ExpenseIntelligenceWidget\n                        kpis={data.kpis}\n                        insight={data.insight}\n                        onInsightEdit={handleInsightEdit}\n                    />\n                </div>\n                <div className=\"xl:col-span-1 h-full\">\n                    <ExpenseDonutChart expenses={data.categories} />\n                </div>\n            </motion.div>\n\n            {/* Bottom Row: Detail Table */}\n            <motion.div variants={item}>\n                <ExpenseDetailTable\n                    categories={data.categories}\n                    history={data.history}\n                    onEditExpense={handleEditExpense}\n                    onDeleteExpense={handleDeleteExpense}\n                    onExport={handleExport}\n                />\n            </motion.div>\n\n            {/* Add/Edit Expense Modal */}\n            <ExpensesFormModal\n                isOpen={isFormOpen}\n                onClose={() => {\n                    setIsFormOpen(false)\n                    setEditingExpense(null)\n                }}\n                expenseToEdit={editingExpense} // Passed correct prop name\n                restaurantId={restaurantId}\n            />\n        </motion.div>\n    )\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Usuario\\.gemini\\antigravity\\playground\\app finanzas restaurante\\src\\components\\financial-control\\ExpensesFormModal.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'OperatingExpenseCategory' is defined but never used. Allowed unused vars must match /^_/u.","line":17,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":17,"endColumn":34,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"OperatingExpenseCategory"},"fix":{"range":[389,414],"text":""},"desc":"Remove unused variable \"OperatingExpenseCategory\"."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":57,"column":21,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":57,"endColumn":24,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[1862,1865],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[1862,1865],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":84,"column":53,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":84,"endColumn":56,"suggestions":[{"messageId":"suggestUnknown","