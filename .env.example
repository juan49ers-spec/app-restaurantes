# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin access
# Comma-separated list of super-admin email addresses.
ADMIN_EMAILS=

# AI / OCR integrations
OPENAI_API_KEY=

# Reporting demo seed
# Keep empty/false in production unless the demo seed endpoint must be explicitly enabled.
ALLOW_REPORTING_DEMO_SEED=

# Logging
# Example: info, warn, error, debug.
LOG_LEVEL=

# E2E tests (local/CI only)
E2E_EMAIL=
E2E_PASSWORD=

# Vercel-provided metadata (usually injected by Vercel, keep empty locally)
VERCEL_GIT_COMMIT_SHA=
